{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "CosmosDb": {
    "ConnectionString": "<YOUR_COSMOS_CONNECTION_STRING>",
    "DatabaseName": "CoursesApp",
    "ContainerName": "courses-db"
  },

  "BlobStorage": {
    "ConnectionString": "<YOUR_BLOB_STORAGE_CONNECTION_STRING>"
  },

  "Cdn": {
    "Endpoint": "https://<YOUR_CDN_ENDPOINT>.azureedge.net",
    "BlobHost": "https://<YOUR_STORAGE_ACCOUNT>.blob.core.windows.net"
  },

  "CognitiveServices": {
    "Endpoint": "https://<YOUR_REGION>.api.cognitive.microsoft.com",
    "ApiKey": "<YOUR_COGNITIVE_SERVICES_KEY>"
  },

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "<YOUR_TENANT_DOMAIN>.onmicrosoft.com",
    "TenantId": "<YOUR_TENANT_ID>",
    "ClientId": "<YOUR_CLIENT_ID>",
    "Audience": "api://<YOUR_CLIENT_ID>"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "https://<YOUR_STATIC_WEB_APP>.azurestaticapps.net"
    ]
  }
}
